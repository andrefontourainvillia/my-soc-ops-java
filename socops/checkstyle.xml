<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle rules for Soc Ops.
  Focus: unused/star imports and consistent code style.
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Disallow trailing whitespace on any line -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="message" value="Line has trailing whitespace."/>
    </module>

    <!-- Each file must end with a newline -->
    <module name="NewlineAtEndOfFile"/>

    <module name="TreeWalker">

        <!-- ── Imports ─────────────────────────────────────────── -->

        <!-- No star/wildcard imports (e.g. import java.util.*;) -->
        <module name="AvoidStarImport"/>

        <!-- No duplicate import statements -->
        <module name="RedundantImport"/>

        <!-- No unused imports -->
        <module name="UnusedImports"/>

        <!-- No imports from sun.* internal packages -->
        <module name="IllegalImport"/>

        <!-- ── Naming conventions ─────────────────────────────── -->

        <!-- Class/interface/enum/record names: PascalCase -->
        <module name="TypeName"/>

        <!-- Method names: camelCase -->
        <module name="MethodName"/>

        <!-- Local variable names: camelCase -->
        <module name="LocalVariableName"/>

        <!-- Constants (static final): UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>

        <!-- ── Whitespace ──────────────────────────────────────── -->

        <!-- Spaces required around most operators and keywords -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
        </module>

        <!-- No whitespace before commas, semicolons, or postfix operators -->
        <module name="NoWhitespaceBefore"/>

        <!-- No whitespace after unary operators -->
        <module name="NoWhitespaceAfter"/>

        <!-- ── Braces ──────────────────────────────────────────── -->

        <!-- Left curly brace must be at end of line (K&R style) -->
        <module name="LeftCurly"/>

        <!-- Right curly brace placement -->
        <module name="RightCurly"/>

        <!-- if/else/for/while/do blocks must always use braces -->
        <module name="NeedBraces"/>

        <!-- ── Misc ────────────────────────────────────────────── -->

        <!-- No empty catch blocks -->
        <module name="EmptyCatchBlock"/>

        <!-- Utility classes (all-static, no public constructor) should have
             a private constructor — already enforced by convention here -->

        <!-- Each top-level class must live in its own file -->
        <module name="OneTopLevelClass"/>

    </module>
</module>
